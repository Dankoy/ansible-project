#!/bin/bash

KEEP_DAYS=30
CURRENT_DATE=$(date +'%Y-%m-%d_%H-%M-%S')

FILE_NAME="pg_${CURRENT_DATE}.sql"
BACKUPS_DIR=~/backups/{{ PROJECT_NAME }}/telegram-chat-service/

DB="{{ TELEGRAM_CHAT_SERVICE_POSTGRES_CONTAINER_DB }}"
HOST="localhost"
USER="{{ TELEGRAM_CHAT_SERVICE_POSTGRES_CONTAINER_USER }}"
PORT="5433"


printf "Removing backups older than $KEEP_DAYS"
printf "$(find $BACKUPS_DIR -type f -name '*.sql' -mtime +$KEEP_DAYS -print)\n"

find $BACKUPS_DIR -type f -name '*.sql' -mtime +$KEEP_DAYS -delete

printf "Starting backup for $DB db ${CURRENT_DATE}\n"

pg_dump -U ${USER} -h ${HOST} -p ${PORT} -Fc -C -d ${DB} -f ${BACKUPS_DIR}${FILE_NAME}

printf "Backup done\n"

